rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 공지사항 이미지
    match /notices/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 배너 이미지
    match /banners/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 인증 신청 이미지 — 로그인 유저만 업로드, 관리자만 읽기
    match /verify_requests/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

  }
}
